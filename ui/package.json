{
  "name": "@ai-crew/ui",
  "version": "0.4.0",
  "description": "AI-Crew Web UI - Design and Configuration Visualization Tool",
  "type": "module",
  "main": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "exports": {
    ".": {
      "import": "./dist/server.js",
      "types": "./dist/server.d.ts"
    },
    "./server": {
      "import": "./dist/server.js",
      "types": "./dist/server.d.ts"
    }
  },
  "files": [
    "dist",
    ".next/standalone",
    ".next/static",
    "public"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build && tsup src/server.ts --format esm --dts --tsconfig tsconfig.build.json",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "@cloudscape-design/components": "^3.0.1251",
    "@cloudscape-design/design-tokens": "^3.0.74",
    "@cloudscape-design/global-styles": "^1.0.54",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-label": "^2.1.6",
    "@radix-ui/react-select": "^2.2.2",
    "@radix-ui/react-separator": "^1.1.6",
    "@radix-ui/react-slot": "^1.2.0",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-tooltip": "^1.2.3",
    "@xyflow/react": "^12.6.5",
    "ai-crew": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dagre": "^0.8.5",
    "lucide-react": "^0.511.0",
    "next": "^15.3.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "swr": "^2.3.3",
    "tailwind-merge": "^3.3.0",
    "yaml": "^2.7.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.1.8",
    "@types/dagre": "^0.7.52",
    "@types/node": "^25.5.0",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "playwright": "^1.58.2",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.1.8",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "@esbuild/darwin-arm64", "sharp"]
  }
