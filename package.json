{
  "name": "ai-crew",
  "version": "0.1.0",
  "description": "AI-DLC methodology + Claude Code Agent Teams integration plugin",
  "author": "seolcongi",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "ai-crew": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format esm --dts",
    "dev": "tsup src/index.ts src/cli.ts --format esm --watch",
    "install:claude": "node dist/cli.js install",
    "lint": "eslint src/",
    "test": "vitest",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist",
    "templates",
    "commands"
  ],
  "keywords": [
    "ai-dlc",
    "claude-code",
    "agent-teams",
    "development-lifecycle",
    "ai-driven-development"
  ],
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "handlebars": "^4.7.8",
    "inquirer": "^9.2.0",
    "yaml": "^2.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0",
    "eslint": "^8.56.0"
  },
  "engines": {
    "node": ">=18"
  }
}
