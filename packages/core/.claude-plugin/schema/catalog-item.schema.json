{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Catalog Item",
  "description": "Schema for catalog items (skills, agents, commands, hooks, mcp, rules, workflows)",
  "type": "object",
  "required": ["id", "version"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^(skill|agent|command|hook|mcp|rules|workflow)\\..+$",
      "description": "Unique catalog item identifier (e.g., skill.planning)"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version"
    },
    "name": {
      "type": "string",
      "description": "Human-readable name"
    },
    "description": {
      "type": "string",
      "description": "Brief description of the item"
    },
    "inputs": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Input dependencies"
    },
    "outputs": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Output artifacts"
    },
    "dependencies": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Catalog item IDs this item depends on"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Tags for search and filtering"
    }
  }
}
