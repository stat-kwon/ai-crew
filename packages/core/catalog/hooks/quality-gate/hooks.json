{
  "description": "Quality gate hooks - run tests after code changes",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/run-tests.sh",
            "timeout": 60
          }
        ]
      }
    ]
  }
}
